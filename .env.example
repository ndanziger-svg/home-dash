# Weather location (Open-Meteo, free, no API key needed)
WEATHER_LAT=40.7128
WEATHER_LON=-74.0060

# Google OAuth - https://console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# SmartThings - https://account.smartthings.com/tokens
SMARTTHINGS_TOKEN=your_smartthings_personal_access_token

# Google Device Access (Nest cameras) - https://console.nest.google.com/device-access
GOOGLE_DEVICE_ACCESS_PROJECT_ID=your_project_id

# Picovoice - https://picovoice.ai
PICOVOICE_ACCESS_KEY=your_picovoice_access_key

# Server
PORT=3000
